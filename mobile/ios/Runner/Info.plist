<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>SoundCheck</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>SoundCheck</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>

	<!-- Network and App Transport Security Configuration -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<!-- Allow HTTPS connections (default is secure) -->
		<key>NSAllowsArbitraryLoads</key>
		<false/>
		<!-- Allow localhost for development/debugging -->
		<key>NSExceptionDomains</key>
		<dict>
			<key>localhost</key>
			<dict>
				<key>NSExceptionAllowsInsecureHTTPLoads</key>
				<true/>
			</dict>
		</dict>
	</dict>

	<!-- Photo Library Access (for image_picker) -->
	<key>NSPhotoLibraryUsageDescription</key>
	<string>SoundCheck needs access to your photo library to upload profile pictures, venue photos, and share your concert experiences.</string>

	<!-- Camera Access (for image_picker) -->
	<key>NSCameraUsageDescription</key>
	<string>SoundCheck needs access to your camera to take photos for your profile, venue reviews, and concert check-ins.</string>

	<!-- Location Access (when in use) -->
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>SoundCheck uses your location to help you discover nearby concert venues, live music events, and connect with other music fans in your area.</string>

	<!-- SEC-061: Removed NSLocationAlwaysAndWhenInUseUsageDescription and
	     NSMotionUsageDescription. These permissions are for unimplemented
	     features (background geofencing, activity detection) and will trigger
	     App Store review scrutiny. Re-add only when the features are built
	     and the usage descriptions accurately reflect functionality. -->
	<key>FlutterDeepLinkingEnabled</key>
	<true/>
	<!-- Custom URL scheme for deep links (e.g., password reset) -->
	<!-- SEC-056: SECURITY WARNING — Custom URL schemes are vulnerable to URI
	     hijacking. For production, migrate to Universal Links with
	     apple-app-site-association. Never pass sensitive tokens via custom
	     scheme without server-side validation. -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLName</key>
			<string>com.soundcheck.app</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>soundcheck</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
