# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/soundcheck
DB_HOST=localhost
DB_PORT=5432
DB_NAME=soundcheck
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_SSL=true

# Authentication
# Generate a strong secret with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_minimum_32_characters_here
JWT_EXPIRES_IN=7d

# Server
PORT=3000
NODE_ENV=development

# WebSocket
ENABLE_WEBSOCKET=true

# Third-party APIs (get your own keys)
FOURSQUARE_API_KEY=your_foursquare_api_key
SETLISTFM_API_KEY=your_setlistfm_api_key

# Ticketmaster Discovery API (required for event sync)
# Get key from: https://developer.ticketmaster.com/
TICKETMASTER_API_KEY=your_ticketmaster_api_key

# Cloudflare R2 Storage (required for photo uploads)
# Get credentials from: Cloudflare Dashboard > R2 > Manage R2 API Tokens
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=soundcheck-photos

# Firebase Cloud Messaging (required for push notifications)
# Download service account JSON from: Firebase Console > Project Settings > Service Accounts
# Set as single-line JSON string or base64 encoded
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Optional: Sentry DSN for error tracking
SENTRY_DSN=

# Redis (optional - falls back to in-memory if not set)
# Used for distributed rate limiting and caching across multiple server instances
REDIS_URL=redis://localhost:6379
