# ============================================================================
# SoundCheck Backend — Environment Variables
# ============================================================================
# Copy to .env for local development. In production (Railway), set these
# as environment variables in the Railway dashboard.
# ============================================================================

# --- TIER 1: Required for app startup ---

# Database (Railway auto-injects DATABASE_URL from PostgreSQL plugin)
DATABASE_URL=postgresql://user:password@localhost:5432/soundcheck
DB_HOST=localhost
DB_PORT=5432
DB_NAME=soundcheck
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_SSL=true

# Authentication
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_minimum_64_characters_here
JWT_EXPIRES_IN=7d

# Server
PORT=3000
NODE_ENV=development

# --- TIER 2: Required for core features ---

# Redis (Railway auto-injects from Redis plugin)
# Used for: distributed rate limiting, BullMQ background jobs, WebSocket pub/sub
REDIS_URL=redis://localhost:6379

# Firebase Cloud Messaging (push notifications)
# Download service account JSON from: Firebase Console > Project Settings > Service Accounts
# Set as single-line JSON string
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Cloudflare R2 Storage (photo uploads)
# Get from: Cloudflare Dashboard > R2 > Manage R2 API Tokens
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=soundcheck-photos
R2_PUBLIC_URL=https://your-r2-public-url.r2.dev

# RevenueCat (subscription webhooks)
# Set shared secret in RevenueCat dashboard > Webhooks
REVENUECAT_WEBHOOK_AUTH=your_revenuecat_webhook_shared_secret

# Email (password reset, notifications)
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_ADDRESS=SoundCheck <noreply@yourdomain.com>

# Social Authentication
# Google: Google Cloud Console > Credentials > OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
# Apple: Apple Developer > Certificates, Identifiers & Profiles
APPLE_BUNDLE_ID=com.yourcompany.soundcheck

# --- TIER 3: Required for full feature set ---

# CORS (required when NODE_ENV=production; mobile apps send no Origin header so this
# mainly affects browser-based API clients like admin tools)
CORS_ORIGIN=https://your-admin-domain.com

# Base URL for share links and Wrapped landing pages
BASE_URL=https://soundcheck-production.up.railway.app

# App Store URLs for share card landing pages
APP_STORE_URL=https://apps.apple.com/app/soundcheck/id000000000
PLAY_STORE_URL=https://play.google.com/store/apps/details?id=com.yourcompany.soundcheck

# Ticketmaster Discovery API (event sync pipeline)
# Get from: https://developer.ticketmaster.com/
TICKETMASTER_API_KEY=your_ticketmaster_api_key

# SetlistFM API (performance history)
# Get from: https://api.setlist.fm/docs/1.0/index.html
SETLISTFM_API_KEY=your_setlistfm_api_key

# Sentry DSN for error tracking (REQUIRED for production)
# Get from: Sentry Dashboard > Settings > Client Keys (DSN)
# Format: https://xxx@o123.ingest.sentry.io/456
# See DEPLOYMENT.md "Sentry Setup" section for full instructions
SENTRY_DSN=https://your-key@your-org.ingest.sentry.io/your-project-id

# --- TIER 4: Optional / has good defaults ---

# WebSocket real-time updates (default: disabled)
ENABLE_WEBSOCKET=true

# Foursquare venue enrichment (default: disabled)
FOURSQUARE_API_KEY=your_foursquare_api_key

# MusicBrainz user agent (default: SoundCheck/1.0)
MUSICBRAINZ_USER_AGENT=SoundCheck/1.0

# ============================================================================
# RAILWAY CONFIGURATION CHECKLIST (BETA-01, BETA-02, BETA-03)
# ============================================================================
# Before beta launch, verify in Railway dashboard (Environment Variables tab):
#
# 1. [ ] NODE_ENV=production (BETA-02)
# 2. [ ] JWT_SECRET — rotated from old value (BETA-01)
# 3. [ ] DATABASE_URL — auto-injected by Railway PostgreSQL plugin
# 4. [ ] REDIS_URL — auto-injected by Railway Redis plugin
# 5. [ ] FIREBASE_SERVICE_ACCOUNT_JSON — single-line JSON
# 6. [ ] CLOUDFLARE_ACCOUNT_ID + R2_ACCESS_KEY_ID + R2_SECRET_ACCESS_KEY
# 7. [ ] R2_BUCKET_NAME + R2_PUBLIC_URL
# 8. [ ] REVENUECAT_WEBHOOK_AUTH
# 9. [ ] RESEND_API_KEY
# 10. [ ] GOOGLE_CLIENT_ID + APPLE_BUNDLE_ID
# 11. [ ] BASE_URL (your Railway URL)
# 12. [ ] APP_STORE_URL + PLAY_STORE_URL
# 13. [ ] TICKETMASTER_API_KEY
# 14. [ ] SETLISTFM_API_KEY — rotated from old value (BETA-01)
# 15. [ ] SENTRY_DSN (create project at sentry.io > copy DSN — see DEPLOYMENT.md)
# 16. [ ] CORS_ORIGIN (if admin web tools exist)
# 17. [ ] ENABLE_WEBSOCKET=true (if desired)
#
# SECRET ROTATION (BETA-01):
# - DB password: Rotate via Railway PostgreSQL plugin settings
# - JWT_SECRET: Generate new with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
#   WARNING: Rotating JWT_SECRET invalidates ALL active user sessions
# - SETLISTFM_API_KEY: Regenerate at setlist.fm account settings
# ============================================================================
