# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/pitpulse
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pitpulse
DB_USER=postgres
DB_PASSWORD=your_database_password

# JWT Configuration
# REQUIRED - Minimum 32 characters
# Generate a strong secret with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-at-least-32-chars
JWT_EXPIRES_IN=7d

# Server Configuration
PORT=3000
NODE_ENV=development

# CORS Configuration
# In production, set to your specific frontend domain(s), comma-separated
# Example: CORS_ORIGIN=https://pitpulse.app,https://www.pitpulse.app
# WARNING: Do not use '*' in production
CORS_ORIGIN=http://localhost:3000

# Third-Party API Keys (Optional)
# SETLISTFM_API_KEY=your-setlistfm-api-key
# FOURSQUARE_API_KEY=your-foursquare-api-key
# MUSICBRAINZ_USER_AGENT=PitPulse/1.0 (contact@yourapp.com)

# Optional: Redis for rate limiting and caching
# REDIS_URL=redis://localhost:6379

# Optional: WebSocket support
# ENABLE_WEBSOCKET=true

# Optional: SSL mode for database connection (production)
# DB_SSL=no-verify

# Optional: Error tracking with Sentry
# SENTRY_DSN=your-sentry-dsn
