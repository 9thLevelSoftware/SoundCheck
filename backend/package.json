{
  "name": "soundcheck-backend",
  "version": "1.0.1",
  "description": "Backend API for SoundCheck mobile application",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "nodemon src/index.ts",
    "build": "node node_modules/typescript/lib/tsc.js",
    "migrate": "node-pg-migrate -j ts --migrations-dir ./migrations --database-url-var DATABASE_URL",
    "migrate:up": "npm run migrate up",
    "migrate:down": "npm run migrate down",
    "migrate:create": "npm run migrate create",
    "migrate:legacy": "ts-node src/scripts/migrate.ts",
    "migrate:events-legacy": "ts-node src/scripts/migrate-events-model.ts",
    "seed": "ts-node src/scripts/seed.ts",
    "seed:dev": "NODE_ENV=development ts-node src/scripts/seed.ts",
    "retention-job": "ts-node src/scripts/retentionJob.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "keywords": [
    "music",
    "venues",
    "bands",
    "reviews",
    "api"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@sentry/node": "^10.32.1",
    "@types/multer": "^2.0.0",
    "apple-signin-auth": "^2.0.0",
    "axios": "^1.13.2",
    "bcryptjs": "^3.0.2",
    "bullmq": "^5.67.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^4.21.2",
    "google-auth-library": "^10.5.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.9.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.16.3",
    "winston": "^3.18.3",
    "winston-daily-rotate-file": "^5.0.0",
    "ws": "^8.19.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.23",
    "@types/jest": "^29.5.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.1.0",
    "@types/pg": "^8.15.5",
    "@types/supertest": "^6.0.0",
    "@types/ws": "^8.18.1",
    "jest": "^29.5.0",
    "nodemon": "^3.1.10",
    "supertest": "^6.3.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src"
    ],
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.d.ts",
      "!src/index.ts"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/src/__tests__/setup.ts"
    ]
  }
}
